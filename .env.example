# Supabase (Settings -> API keys). Новый формат ключей:
#   publishable (sb_publishable_...) -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#   secret      (sb_secret_...)      -> SUPABASE_SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# СЕКРЕТ: только Vercel env / локальный .env.local, используется ТОЛЬКО в cron-синке
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Kaiten
KAITEN_API_URL=https://your-company.kaiten.ru
KAITEN_API_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Защита cron-эндпоинтов: openssl rand -hex 32
CRON_SECRET=change-me
